{
  "manifest_version": 3,
  "name": "PhishGuard Upload Analyzer",
  "version": "1.0.0",
  "description": "Analyse un email .eml via le backend local PhishGuard.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "PhishGuard Upload Analyzer"
  }
}
